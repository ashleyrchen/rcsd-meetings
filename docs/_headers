# Cloudflare Pages custom response headers.
# Format: https://developers.cloudflare.com/pages/configuration/headers/
#
# Font binaries are content-stable: a changed font ships under a new
# filename, so browsers may cache them for a year and never revalidate.
# Deliberately NOT covered: /fonts/fonts.css (its @font-face rules can
# change between deploys) and HTML (Pages' default revalidation keeps
# deploys visible immediately).

/fonts/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Images are NOT immutable: principal headshots live at slug-named paths
# (/img/principals/<school>.jpg, written in place by build-schools.mjs),
# so a replaced photo must be able to show up within a day.

/img/*
  Cache-Control: public, max-age=86400
