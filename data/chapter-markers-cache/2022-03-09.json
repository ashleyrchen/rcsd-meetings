        "publicComments": [
          {
            "name": "Eric (technology staff)",
            "startSeconds": 543,
            "endSeconds": 756,
            "summary": "Read a letter on behalf of the district technology team describing how classified tech staff were required to work on-site throughout the pandemic without receiving the same financial compensation as teachers who were later incentivized to return."
          },
          {
            "name": "Ryan Sue",
            "startSeconds": 798,
            "endSeconds": 996,
            "summary": "Followed up on the letter, questioning why the tech department and other classified staff who worked on-site the entire pandemic were not offered the same financial incentives as teachers, and expressing disappointment that the proposed MOU compensation of five restricted holidays was not comparable to the teacher stipend."
          },
          {
            "name": "Maria Stockton",
            "startSeconds": 1023,
            "endSeconds": 1166,
            "summary": "A 43-year district employee described a decline in respect for classified staff, noted inequitable treatment compared to certificated staff during COVID, and invited board members to visit schools and speak directly with classified employees."
          },
          {
            "name": "Ana Solorio",
            "startSeconds": 1170,
            "endSeconds": 1309,
            "summary": "Presented a letter with signatures from classified members requesting board support in MOU negotiations, emphasizing that classified workers who were on-site during the pandemic deserve compensation comparable to the teacher stipends, not just five holiday days."
          },
          {
            "name": "Johanna Rasmussen",
            "startSeconds": 1599,
            "endSeconds": 1689,
            "summary": "Described her fourth-grade son being assaulted for the third time at Roosevelt School despite a safety plan in place, and asked the board to intervene and address escalating bullying and violence on the school's playground."
          }
        ],
        "consent": false,
        "pulled": false
      },
