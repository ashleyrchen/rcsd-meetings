        "publicComments": [
          {
            "name": "Noah Gaspar",
            "startSeconds": 190,
            "endSeconds": 244,
            "summary": "As a parent of an incoming TK student at Orion, he expressed concern about the lack of on-campus aftercare options for TK-age children and asked the board to help find solutions."
          },
          {
            "name": "Hai-Ching Yang",
            "startSeconds": 267,
            "endSeconds": 365,
            "summary": "As a parent of an incoming TK student at Orion, she echoed concerns about insufficient aftercare options for working families and urged the board to open additional classrooms and extend aftercare eligibility to children 4 years and older."
          },
          {
            "name": "Michelle Stroebe",
            "startSeconds": 552,
            "endSeconds": 619,
            "summary": "Thanked Dr. Baker for the update on aftercare challenges, expressed appreciation for the board's efforts, and offered parent support in addressing the TK aftercare situation."
          }
        ],
        "consent": false,
        "pulled": false
      },
      {
        "itemLabel": "9",
        "title": "Discussion of Citizens' Initiative and District-Sponsored Parcel Tax",
        "phases": {
          "opened": 620,
          "presentation": 671,
          "publicComment": 1806,
          "discussion": 2217,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Carlo Contavalli",
            "startSeconds": 1828,
            "endSeconds": 1958,
            "summary": "As a parent and proponent of the citizens' initiative parcel tax, he described the district's funding challenges and expressed support for a square-footage-based parcel tax as an urgent priority."
          },
          {
            "name": "Jessica Shade",
            "startSeconds": 1982,
            "endSeconds": 2103,
            "summary": "As a leader of the citizens' initiative effort, she expressed support for any form of parcel tax and stated that if the district poll does not show sufficient support for a district-sponsored measure, she will continue pursuing the citizens' initiative."
          },
          {
            "name": "Adina Olsen",
            "startSeconds": 2130,
            "endSeconds": 2215,
            "summary": "As a parent working on the citizens' initiative, she echoed support for additional school funding through either a district-sponsored or citizens' initiative parcel tax."
          }
        ],
        "consent": false,
        "pulled": false
      },
