      {
        "itemLabel": "13",
        "title": "Action Items – Item 13.1: Approval of Permanently Renaming 170 Selby Lane as Adelante Selby Spanish Immersion School",
        "phases": {
          "opened": 5060,
          "presentation": 5088,
          "publicComment": 5480,
          "discussion": 6110,
          "vote": {
            "seconds": 6806,
            "type": "roll-call",
            "result": "5-0 (motion to reject the proposed name)"
          }
        },
        "publicComments": [
          {
            "name": "Michelle Smith",
            "startSeconds": 5507,
            "endSeconds": 5705,
            "summary": "Advocated that the name should be either Adelante Spanish Immersion or Unidos rather than Adelante Selby, which she felt was a compromise that satisfied neither community."
          },
          {
            "name": "Rita Melton",
            "startSeconds": 5729,
            "endSeconds": 5943,
            "summary": "Read a letter on behalf of Adelante teachers opposing the name Adelante Selby, arguing that 'Selby' has no connection to bilingualism and that if the name cannot be Adelante, Unidos would be an acceptable second choice."
          },
          {
            "name": "James Carrig",
            "startSeconds": 5982,
            "endSeconds": 6086,
            "summary": "Expressed disappointment that teachers were still advocating for the Adelante name and suggested a completely fresh new name, also questioning whether a board member who is a parent at the school should abstain from the vote."
          }
        ],
        "consent": false,
        "pulled": false
      },
