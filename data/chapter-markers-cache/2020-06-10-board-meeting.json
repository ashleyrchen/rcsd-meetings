      {
        "itemLabel": "7.5",
        "title": "Approval of Permanently Renaming the 170 Selby Lane in Atherton site as Adelante Selby Spanish Immersion School",
        "phases": {
          "opened": 9043,
          "presentation": 9054,
          "publicComment": 9187,
          "discussion": 9890,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Suzanne Ruiz Dunlap",
            "startSeconds": 9243,
            "endSeconds": 9304,
            "summary": "Thanked the naming committee and Dr. Baker, expressed support for the recommendation to permanently name the school Adelante Selby Spanish Immersion School."
          },
          {
            "name": "Michelle Smith",
            "startSeconds": 9316,
            "endSeconds": 9522,
            "summary": "Expressed frustration with the overall naming process, questioning why the community vote was not honored the first time and criticizing the process as undemocratic."
          },
          {
            "name": "Jonathan Cantu",
            "startSeconds": 9571,
            "endSeconds": 9688,
            "summary": "Expressed disappointment that the board initially rejected the naming recommendation and voiced concern about the community losing both their campus and potentially their name."
          },
          {
            "name": "Chris Rosone",
            "startSeconds": 9706,
            "endSeconds": 9751,
            "summary": "Affirmed community attachment to the Adelante Selby identity and expressed concern that the loudest voices at the end of the process had overtaken the broader community's wishes."
          },
          {
            "name": "Devin Mulaney",
            "startSeconds": 9809,
            "endSeconds": 9888,
            "summary": "Urged the board to wrap up the naming process quickly given other pressing priorities, and noted that 'Mid Peninsula' could be confused with a nearby continuation school."
          }
        ],
        "consent": false,
        "pulled": false
      },
