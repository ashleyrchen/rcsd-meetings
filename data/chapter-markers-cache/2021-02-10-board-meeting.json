          "discussion": 3266,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Marisol Mendoza",
            "startSeconds": 7963,
            "endSeconds": 8076,
            "summary": "An instructional assistant at Henry Ford expressed disappointment that the district rejected CSEA's request for extra compensation for classified staff working on-site during the pandemic, arguing that their workload and health risks have increased just as teachers' have."
          },
          {
            "name": "Michael Hofer",
            "startSeconds": 8135,
            "endSeconds": 8190,
            "summary": "A Roy Cloud parent asked what the plan B would be if the current vaccine-dependent reopening plan does not materialize, and when parents would know whether children would return in person by April or by August."
          },
          {
            "name": "Maria Stockton",
            "startSeconds": 8576,
            "endSeconds": 8769,
            "summary": "A classified staff representative challenged the board to visit school sites and witness the increased workloads of bus drivers, office staff, food service, tech, and instructional assistants, and requested that classified employees be given an opportunity to present to the board about how their jobs have changed during the pandemic."
          }
        ],
        "consent": false,
