          {
            "name": "Maria Stockton",
            "startSeconds": 197,
            "endSeconds": 340,
            "summary": "CSEA President announced a new CSEA scholarship for graduating eighth graders, highlighted Classified Employee Appreciation Week activities, and invited board members to a Welcome Back Classified Appreciation Family Picnic on August 23rd."
          },
          {
            "name": "Husham Sharifi",
            "startSeconds": 363,
            "endSeconds": 501,
            "summary": "A prospective RCSD parent described how his daughter was dropped from the Orion Mandarin Immersion TK enrollment register without any written or email notification, leaving his family without a school placement for the upcoming year."
          },
          {
            "name": "Susanne Ruiz-Dunlap",
            "startSeconds": 549,
            "endSeconds": 649,
            "summary": "A kindergarten teacher at Adelante Selby expressed concern that the district had no plan for early release days or staggered start for kindergarten despite class sizes of up to 28, and urged the board to reconsider the kindergarten start schedule and include teachers in related conversations."
          }
        ],
        "consent": false,
        "pulled": false
