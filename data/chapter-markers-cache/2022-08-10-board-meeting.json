      {
        "itemLabel": "14.1",
        "title": "Adoption of Resolution 2, Ordering a School Bond Election on November 8, 2022",
        "phases": {
          "opened": 719,
          "presentation": 751,
          "publicComment": 1071,
          "discussion": 977,
          "vote": {
            "seconds": 2584,
            "type": "roll-call",
            "result": "5-0"
          }
        },
        "publicComments": [
          {
            "name": "Chris Robel",
            "startSeconds": 1329,
            "endSeconds": 1577,
            "summary": "Opposed the bond measure, arguing it was a bad time for new taxes, that a parcel tax would be more equitable and flexible, and raising concerns about enrollment decline, interest costs to taxpayers, and the measure's inability to fund teachers or academic programs."
          },
          {
            "name": "Katerina Schwaidenbeck",
            "startSeconds": 1613,
            "endSeconds": 1736,
            "summary": "Supported the bond, describing poor bathroom and kitchen facilities at her daughter's school and how a central kitchen could improve the quality and nutritional value of school meals."
          },
          {
            "name": "Jessica Shade",
            "startSeconds": 1764,
            "endSeconds": 1884,
            "summary": "Supported the bond, citing the need for updated health, safety, and educational facilities, the potential for a central kitchen for healthier meals, and praising the district's track record of completing Measure T on time and under budget."
          },
          {
            "name": "Jessica Meunier",
            "startSeconds": 1947,
            "endSeconds": 2053,
            "summary": "Supported the bond, expressing excitement about the central kitchen potential for improved nutrition, updated safety standards, and the district's track record of fiscal responsibility."
          },
          {
            "name": "Elmer Martinez",
            "startSeconds": 2071,
            "endSeconds": 2131,
            "summary": "Supported the bond as a community volunteer, emphasizing the need for critical facility upgrades at aging schools to meet health, safety, and educational standards and strengthen community property values."
          },
          {
            "name": "Ileana Harrison",
            "startSeconds": 2149,
            "endSeconds": 2288,
            "summary": "Supported the bond as a pediatrician and parent, praising the new Orion building, noting broad parent support, and advocating especially for a central kitchen to enable cooking fresh meals for students."
          }
        ],
        "consent": false,
        "pulled": false
      },
