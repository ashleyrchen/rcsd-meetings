        "publicComments": [
          {
            "name": "Azil",
            "startSeconds": 190,
            "endSeconds": 279,
            "summary": "A fifth-grade student advocated for an advanced English ELA class at Kennedy Middle School, explaining her personal goals and language background."
          },
          {
            "name": "Nia Seeberger",
            "startSeconds": 296,
            "endSeconds": 454,
            "summary": "A student born in China advocated for advanced English coursework at Kennedy, arguing that without it students like her will not be prepared for AP classes in high school."
          },
          {
            "name": "Maple",
            "startSeconds": 468,
            "endSeconds": 562,
            "summary": "A student with high iReady scores explained she feels bored and disengaged without sufficiently challenging curriculum and asked the board to add advanced ELA at Kennedy."
          },
          {
            "name": "Maya Rose Felix",
            "startSeconds": 579,
            "endSeconds": 679,
            "summary": "A student whose parents could not help her with homework advocated for advanced English at Kennedy, stating she needs it to pursue her dream of becoming a lawyer."
          },
          {
            "name": "Greta",
            "startSeconds": 694,
            "endSeconds": 820,
            "summary": "A Mandarin Immersion fifth-grader asked the board to add advanced English and other challenging classes at Kennedy, noting she loses focus when lessons move too slowly."
          },
          {
            "name": "Luis Velazquez",
            "startSeconds": 838,
            "endSeconds": 1023,
            "summary": "A parent and executive coach argued that removing advanced coursework in the name of equity is regressive and asked the board to reinstate Advanced ELA at Kennedy."
          },
          {
            "name": "Alexis Velazquez",
            "startSeconds": 1046,
            "endSeconds": 1112,
            "summary": "A fifth-grade student at Orion with eighth-grade iReady scores asked the board to add as many advanced classes as possible at Kennedy, including Advanced ELA and science."
          },
          {
            "name": "Olbia",
            "startSeconds": 1125,
            "endSeconds": 1208,
            "summary": "A fifth-grade student planning to attend Kennedy asked the board to reinstate Advanced ELA, comparing it to the existing advanced math program and noting differing student appetites for challenge."
          },
          {
            "name": "Megan",
            "startSeconds": 1237,
            "endSeconds": 1420,
            "summary": "A community member argued that limiting advanced coursework is ethically dubious, weakens public schools, and asked the district to expand accelerated curriculum to more school sites beyond Northstar."
          }
        ],
        "consent": false,
        "pulled": false
      },
