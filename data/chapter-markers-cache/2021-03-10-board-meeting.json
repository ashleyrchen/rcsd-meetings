      {
        "itemLabel": "12",
        "title": "COVID-19 and Reopening Update",
        "phases": {
          "opened": 2470,
          "presentation": 2492,
          "publicComment": 5738,
          "discussion": 7140,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Pam Barash",
            "startSeconds": 5757,
            "endSeconds": 5925,
            "summary": "A kindergarten teacher expressed concern that staff who travel over spring break may be required to quarantine upon return despite being vaccinated, and asked whether the same quarantine requirement would apply to students and families, given that schools were reopening only three days after spring break."
          },
          {
            "name": "Indra Hernandez",
            "startSeconds": 5977,
            "endSeconds": 6178,
            "summary": "A CDC/preschool staff member raised concerns about inconsistent COVID protocols across sites, the wellness survey being misunderstood, uneven enforcement of Wednesday off-campus rules, the timing of second vaccine doses relative to the return date, and requested COVID testing for students before they enter preschool classrooms."
          },
          {
            "name": "Stephanie Chen",
            "startSeconds": 6248,
            "endSeconds": 6407,
            "summary": "A parent asked whether the district could establish more uniform return-to-school formats across all schools for equity reasons, rather than having disparate plans at each site."
          },
          {
            "name": "Shawna Hackworth",
            "startSeconds": 6592,
            "endSeconds": 6656,
            "summary": "A parent asked whether students currently placed at a school of choice would lose their placement for the following year if they chose to enroll in the proposed virtual academy for 2021-22."
          }
        ],
        "consent": false,
        "pulled": false
      },
