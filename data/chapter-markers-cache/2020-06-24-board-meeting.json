      {
        "itemLabel": "14.2",
        "title": "Approval of 2020-21 Proposed Budget for Redwood City School District",
        "phases": {
          "opened": 3831,
          "presentation": 3839,
          "publicComment": 4729,
          "discussion": 4613,
          "vote": {
            "seconds": 5736,
            "type": "roll-call",
