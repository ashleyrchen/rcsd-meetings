      {
        "itemLabel": "3",
        "title": "Study Session: Discussion on Dyslexia",
        "phases": {
          "opened": 92,
          "presentation": 103,
          "publicComment": 1764,
          "discussion": 3022,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Ors Neighbor",
            "startSeconds": 1778,
            "endSeconds": 1987,
            "summary": "A father described his son Leor's experience being diagnosed with dyslexia privately at significant expense after the school determined he did not qualify for special education services despite low reading scores, and urged the district to support all students regardless of financial means."
          },
          {
            "name": "Giselle Hale",
            "startSeconds": 2022,
            "endSeconds": 2221,
            "summary": "A parent of two dyslexic students and community advocate urged the board to treat dyslexia as a general education issue, highlighted districts succeeding through Orton-Gillingham training for all teachers, and stressed that implementation fidelity matters more than curriculum choice alone."
          },
          {
            "name": "Fallon Scoggins",
            "startSeconds": 2229,
            "endSeconds": 2590,
            "summary": "A mother of a son with severe dyslexia and dysgraphia described the emotional and academic toll on her family, the inaccessibility of after-school interventions for many families, and urgently called for structured literacy instruction to be available throughout the school day for all students."
          },
          {
            "name": "Jennifer Salma",
            "startSeconds": 2607,
            "endSeconds": 3022,
            "summary": "A regional leader with Decoding Dyslexia California thanked the district for engaging with the California Dyslexia Guidelines, emphasized dyslexia as a neurological difference with associated strengths rather than a disability, and urged fidelity in program implementation and robust principal and teacher support."
          }
        ],
        "consent": false,
        "pulled": false
      },
