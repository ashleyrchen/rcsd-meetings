        "itemLabel": "9",
        "title": "Parcel Tax Discussion for November 2024 Ballot",
        "phases": {
          "opened": 459,
          "presentation": 545,
          "publicComment": 2845,
          "discussion": 1580,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Jessica Shade",
            "startSeconds": 2858,
            "endSeconds": 2959,
            "summary": "A parent of two students at Orion expressed strong support for a parcel tax to replace expiring COVID stimulus funds and to maintain mental health counselors, reading specialists, class aides, ESL support, STEAM instructors, and class-size reduction."
          },
          {
            "name": "Brandon Matthews",
            "startSeconds": 2977,
            "endSeconds": 3002,
            "summary": "A homeowner and parent of a kindergartner in Redwood City voiced support for moving as quickly as possible toward a parcel tax to support the schools."
          },
          {
            "name": "Elizabeth Flagle",
            "startSeconds": 3026,
            "endSeconds": 3114,
            "summary": "A parent and former PTO board member at Adelante Selby expressed support for the parcel tax feasibility study while urging the board to learn from the lessons of Measure H's narrow defeat and to look at strategies to counter online opposition, and also noted a technical barrier preventing a fellow parent from submitting a speaker card."
          }
        ],
        "consent": false,
