        "publicComments": [
          {
            "name": "Maria Stockton",
            "startSeconds": 146,
            "endSeconds": 215,
            "summary": "Introduced herself as the new CSEA Chapter President and thanked her negotiating team and district representatives for productive classified employee negotiations."
          },
          {
            "name": "Diana Escalante Ocon",
            "startSeconds": 233,
            "endSeconds": 410,
            "summary": "As a 14-year librarian at Adelante Selby, she explained in detail how every minute of her schedule is used and argued that reducing her hours from 37.5 to 30 per week would significantly impair essential library maintenance and student services."
          },
          {
            "name": "Devon Mullane",
            "startSeconds": 410,
            "endSeconds": 536,
            "summary": "An 8th grade teacher at Hoover, he expressed appreciation for Hoover administration, advocated for support staff district-wide, and specifically praised the librarians by name for their dedication to students."
          },
          {
            "name": "Meghan O'Reilly Green",
            "startSeconds": 614,
            "endSeconds": 783,
            "summary": "A parent in the Orion Mandarin Immersion program, she expressed support for placing a second Co-op TK class in the second enrollment round and called for community-wide discussion about growth at Orion given that projections had underestimated enrollment."
          }
        ],
        "consent": false,
        "pulled": false
      },
