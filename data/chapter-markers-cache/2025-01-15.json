        "itemLabel": "7.1",
        "title": "Public Hearing regarding the Connect Community Charter School Renewal Petition",
        "phases": {
          "opened": 5322,
          "presentation": 5539,
          "publicComment": 6550,
          "discussion": null,
          "vote": null
        },
        "publicComments": [
          {
            "name": "Julio Suchite",
            "startSeconds": 6574,
            "endSeconds": 6770,
            "summary": "Spoke in Spanish (interpreted) expressing deep gratitude to the board and community, emphasizing trust in the teachers and the transformative impact Connect has had on his family."
          },
          {
            "name": "Amanda Vaughn",
            "startSeconds": 6987,
            "endSeconds": 7170,
            "summary": "Spoke as Connect's art and newcomer teacher, praising the school's implementation of systematic ELD for newcomer students and the quality of the school's art program."
          },
          {
            "name": "Meda Okelo",
            "startSeconds": 7170,
            "endSeconds": 7238,
            "summary": "Described joining Connect as a long-term guest teacher, praised its SEL and project-based learning focus, and strongly urged the board to renew the charter."
          },
          {
            "name": "Anton Estaniel",
            "startSeconds": 7343,
            "endSeconds": 7504,
            "summary": "Spoke as Connect's music teacher, describing the school-wide musical production 'Space is the Place' as a powerful example of project-based learning involving nearly every student."
          },
          {
            "name": "Walter Soto Franco",
            "startSeconds": 7529,
            "endSeconds": 7633,
            "summary": "A recent Connect graduate originally from Guatemala shared how the school helped him learn English and develop his skills, expressing deep gratitude to the staff."
          },
          {
            "name": "Itzamar Giron",
            "startSeconds": 7678,
            "endSeconds": 7811,
            "summary": "A Connect alumna now studying mechanical engineering at San Francisco State shared how the school made a lasting positive impact on her life and spoke fondly of her teachers and the school community."
          },
          {
            "name": "Ashley Solis",
            "startSeconds": 7860,
            "endSeconds": 7888,
            "summary": "An eighth-grade current Connect student shared that the school helped her learn to speak and read in English and that the staff treats students well."
          }
        ],
        "consent": false,
        "pulled": false
      },
